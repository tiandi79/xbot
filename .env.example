# DashScope — 评论生成（必填）
# 运行: python run.py  （或 run.bat / scripts\run_auto_comment.bat）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DASHSCOPE_MODEL=qwen-plus
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_PROXY=socks5://127.0.0.1:1080

# X 登录 cookies
COOKIES_PATH=data/x.com.cookies.json

# Chrome CDP 启动时的 SOCKS5/HTTP 代理（xbot 专用 Chrome，与日常 Chrome 分开）
# CHROME_PROXY=socks5://127.0.0.1:1080

# 评论风格（本地私有，不进仓库；从 .example 复制后编辑）
# copy data\comment_style.md.example data\comment_style.md
# copy data\comment_style_examples.md.example data\comment_style_examples.md
# COMMENT_STYLE_PATH=data/comment_style.md
# COMMENT_STYLE_EXAMPLES_PATH=data/comment_style_examples.md
# COMMENT_STYLE_EXTRA=一两句额外补充，会追加到 system prompt
# X_USERNAME=your_handle

# 自动评论末尾标记（见 data/auto_comment_marker.md）
# COMMENT_MARKER_SECRET=随机私密串
# COMMENT_MARKER_DISABLED=1

# 评论条数与间隔（见 .env，命令行可覆盖）
# MAX_COMMENTS=1          # 每次最多发几条；0=不限，一直发
# COMMENT_INTERVAL_SEC=60 # 每条间隔基准秒数（MAX_COMMENTS=1 时不等待）
# COMMENT_INTERVAL_JITTER_MIN=0.5
# COMMENT_INTERVAL_JITTER_MAX=1.5
# COMMENT_SCRAPE_BATCH=30   # MAX_COMMENTS=0 时每轮最多扫描候选帖数

# 帖子过滤：最低浏览量（中文帖、非广告且 views >= 该值才评论）
# MIN_VIEWS=10000

# 滚动防检测（可选）
# SCROLL_MIN=800
# SCROLL_MAX=2800
# SCROLL_PAUSE_MIN=1.2
# SCROLL_PAUSE_MAX=3.5
